{
  "manifest_version": 3,
  "name": "QR CODE",
  "version": "1.0.0",
  "description": "Generate QR code of current page or custom input",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["activeTab", "storage"],
  "icons": {
    "16": "icons/logo-16.png",
    "48": "icons/logo-48.png",
    "128": "icons/logo-128.png"
  }
}
